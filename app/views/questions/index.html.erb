<% set_meta_tags title: "質問コーナー" %>
<div class="main users-index">
  <div class="container">

    <h1 class="users-heading">質問コーナー</h1>

	<%= form_for([@user, @user.questions.build]) do |f| %>

	    <p>本文</p>
	    <%= f.text_area :content, class: 'form-control', placeholder: "質問を書いてください！" %>       

	<%= f.submit "質問する" %>
	<% end %>



  </div>
</div>