<% set_meta_tags title: "#{@user.name}の質問コーナー",

				og: { 
					title: "登録不要！匿名で「#{@user.name}」に質問ができます！",
					description: "", 
					image: image_url('/images/qa_top.jpg')
				},

				twitter: { card: 'summary_large_image'} 
%>

<div class="main users-index">
  <div class="container bg_white">
  	    <%= render "/layouts/breadcrumb" %>


	<%= link_to user_questions_path(@user) do %>
	    <h1 class="users-heading">質問コーナー</h1>
	<% end %>

	<div class="qa_wrap">

			<div class="qa_profile_wrap">

			<%= render "/questions/profile" %>
			
			</div>

			
			<div class="qa_answer_form">
				<%= form_for ([@user, @question]) do |f| %>

					<%= f.text_area :content, class: 'form-control form-note', placeholder: "質問を書いてください！（80文字以内）" %> 
	
						<input type="submit" name="commit" value="質問する" data-disable-with="質問する" class="submit_btn">

					<div class="reset"></div>

				<% end %>
		 	 </div>


			<% if admin_user_signed_in?  %>
				<% if @user.id == current_admin_user.id %>
					<div class="qa_tw_share">
						<%= link_to("https://twitter.com/share?url=#{request.url}&text=質問を募集中です！%0a%0a%23質問コーナー%20%23サークルブック%0a", target: '_blank') do %>
							<div class="share_btn_tw">
							     <i class="fa fa-twitter"></i>質問をTwitterで募集する！
							</div>
						<% end %>
					</div>
				<% end %>
			<% end %>


	</div>


	<div class="qa_card_warp">

		<div class="qa_card_txt">
			▼ <%= @user.name %>さんに寄せられた質問です！
		</div>


		<ul>
			<% if @questions.any? %>
				<% @questions.each do |question| %>
					<li class="ribbon-wrapper">
						<div class="ribbon-content">
							<% if question.answer.nil? %>
							  <span class="ribbon red">未回答</span>
							<% else %>
						  		<span class="ribbon green">回答済み</span>
							<% end %>
						</div>

						<%= link_to "/users/#{@user.id}/questions/#{question.id}" do %>
	 						<img data-src="https://res.cloudinary.com/hgvtbyy8v/image/upload/l_text:Sawarabi%20Gothic_60:<%= question.content %>,y_-35,co_rgb:333333,w_900,c_fit/v1586676520/qa_vipkmx.jpg" alt="<%= question.content %>" class="lazyload">
	 						<div class="qa_judge">
	 						</div>
						<% end %>	
					</li>
				<% end %>
			<% end %>



			<% @questions.each do |question| %>
				<% if question.content == @question_first %>
					<% @question_first_count = 1 %>
				<% elsif question.content == @question_second %>
					<% @question_second_count = 1 %>
				<% else question.content == @question_third %>
					<% @question_third_count = 1 %>
				<% end %>
			<% end %>

				<% if @question_first_count != 1 %> 
					<li class="ribbon-wrapper">
						<div class="ribbon-content">
							<span class="ribbon red">未回答</span>
						</div>
						<%= link_to controller: :questions, action: :question, sample: "first" do %>
	 						<img data-src="https://res.cloudinary.com/hgvtbyy8v/image/upload/l_text:Sawarabi%20Gothic_60:<%= @question_first %>,y_-35,co_rgb:333333,w_900,c_fit/v1586676520/qa_vipkmx.jpg" alt="<%= @question_first %>" class="lazyload">
						<% end %>		
					</li>
				<% end %>

				<% if @question_second_count != 1 %> 
					<li class="ribbon-wrapper">
						<div class="ribbon-content">
							<span class="ribbon red">未回答</span>
						</div>
						<%= link_to controller: :questions, action: :question, sample: "second" do %>
	 						<img data-src="https://res.cloudinary.com/hgvtbyy8v/image/upload/l_text:Sawarabi%20Gothic_60:<%= @question_second %>,y_-35,co_rgb:333333,w_900,c_fit/v1586676520/qa_vipkmx.jpg" alt="<%= @question_second %>" class="lazyload">
						<% end %>		
					</li>
				<% end %>

				<% if @question_third_count != 1 %> 
					<li class="ribbon-wrapper">
						<div class="ribbon-content">
							<span class="ribbon red">未回答</span>
						</div>
						<%= link_to controller: :questions, action: :question, sample: "third" do %>
	 						<img data-src="https://res.cloudinary.com/hgvtbyy8v/image/upload/l_text:Sawarabi%20Gothic_60:<%= @question_third %>,y_-35,co_rgb:333333,w_900,c_fit/v1586676520/qa_vipkmx.jpg" alt="<%= @question_third %>" class="lazyload">
						<% end %>		
					</li>
				<% end %>

		</ul>

	</div>		


  </div>
</div>