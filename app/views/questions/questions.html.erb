<% set_meta_tags title: "質問の一覧" %>


<div class="main users-index">
  <div class="container bg_white">

	    <h1 class="users-heading">質問コーナーの一覧</h1>


		<div class="qa_card_warp">

			<% if @questions.any? %>
					<ul>
						<% @questions.each do |question| %>
						<li class="ribbon-wrapper">
							<div class="ribbon-content">
								<% if question.answer.nil? %>
								  <span class="ribbon red">未回答</span>
								<% else %>
							  		<span class="ribbon green">回答済み</span>
								<% end %>
							</div>

							<%= link_to "/users/#{question.user.id}/questions/#{question.id}" do %>
		 						<img src="https://res.cloudinary.com/hgvtbyy8v/image/upload/l_text:Sawarabi%20Gothic_60:<%= question.content %>,y_-35,co_rgb:333333,w_900,c_fit/v1586676520/qa_vipkmx.jpg" alt="<%= question.content %>">
		 						<div class="qa_judge">
		 						</div>
							<% end %>	
						</li>
						<% end %>
					</ul>
			<% end %>

		</div>		


  </div>
</div>