<% @places.each do |place| %>


  <div class="users-index-item ribbon-wrapper">

      <div class="ribbon-content">
        <% if place.tag.to_i == 1 %>
          <span class="ribbon green">屋内</span>
        <% else place.tag.to_i == 2 %>
          <span class="ribbon blue">屋外</span>
        <% end %>
      </div>

      <div class="user-content">

        <div class="list_wrapper">
          <div class="list_01">
            <h2 class="place_name"><%= place.name.truncate(24) %></h2>
          </div>

          <div class="list_02">
            <h3 class="place_d">
              <%= place.prefecture.name %><%= place.city.name %>にある<br>
              <%= place.event.name %>のコート情報
            </h3>
          </div>

        </div>

      </div>

      <% if place.img_link.present? && place.img_url.present? && place.img_source.present? %>
        <div class="img_source_wrap">
          <img src="<%= place.img_link %>" alt="" class="img_source">
          <div class="img_url_source">
            出典：<a href="<%= place.img_url %>" class="image_link"><%= place.img_source %></a>
          </div>
        </div>
      <% end %>      

      <div class="border"></div>

      <div class="article_item article_padding place_list ">
        <table>
          <tbody>

          <tr class="flex_contents">
            <th class="flex_list">住所</th>
            <td class="flex_list"><%= place.address %></td>
          </tr>
          <tr class="flex_contents">
            <th class="flex_list">駐車場情報</th>
            <td class="flex_list"><%= place.parking %></td>
          </tr>
          <tr class="flex_contents">
            <th class="flex_list">利用可能時間</th>
            <td class="flex_list"><%= place.time %></td>
          </tr>
          <tr class="flex_contents">
            <th class="flex_list">定休日</th>
            <td class="flex_list"><%= place.regular_holiday %></td>
          </tr>
          <tr class="flex_contents">
            <th class="flex_list">施設規模</th>
            <td class="flex_list"><%= place.scale %></td>
          </tr>
          <tr class="flex_contents">
            <th class="flex_list">利用料金</th>
            <td class="flex_list"><%= place.price %></td>
          </tr>
          <tr class="flex_contents">
            <th class="flex_list">電話番号</th>
            <td class="flex_list"><%= place.tel %></td>
          </tr>

          </tbody>
        </table> 
      </div>
      
      <%= link_to "詳細を確認する", "/places/#{place.event.ruby}/#{place.prefecture.kana}/#{place.city.city_kana}/#{place.id}", class: "place_more" %>

  </div> <!-- 各フレーム -->



<% end %>

<%= render "/layouts/ad_square" %>




