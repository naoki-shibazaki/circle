<% set_meta_tags title: "【#{Time.now.strftime("%Y")}年版】#{@prefecture.name}にある#{@event.name}コートの情報一覧ページ",
                 description: "#{@prefecture.name}にある#{@event.name}コートの情報一覧ページです。体育館やアリーナ、屋外にある公園などの情報を分かりやすく掲載しています！住所やアクセス方法、駐車場情報も載っているので便利です。また、#{@prefecture.name}で活動している#{@event.name}サークルやチーム、団体などの情報も掲載しています！",
	              og: { 
	              	image:image_url("/images/events/e_icon_#{@event.ruby}.jpg")
	              },
				twitter: { card: 'summary'}  
 %>


<div class="main users-index">
  <div class="container">

    <%= render "/layouts/breadcrumb" %>
    <div class="e_header_wrap">
		<img src="/images/events/e_icon_<%= @event.ruby %>.jpg" alt="<%= @event.name %>" >
      <div class="link_txt">
        <h1 class="e_header_title">
		    <%= @prefecture.name %>にある<br><%= @event.name %>のコートや施設情報
        </h1>
      </div>
    </div>

	<div class="search_area">
		<div class="coat-container">

		  <div class="cp_actab">

			    <input id="tab-one" type="checkbox" name="tabs">

			    <label for="tab-one"></i><%= @prefecture.name %>の市区郡から探す</label>


		  	<div class="cp_actab-content">
				<% @cities.each do |city| %>
					<div class="prefecture_city_list">

						<%= link_to("/places/#{@event.ruby}/#{@prefecture.kana}/#{city.city_kana}") do %>
			                <%= city.name %>
		                <% end %>

					</div>
				<% end %>
		   	</div>

		  </div>


		</div>
	</div>


    <%= render "/places/places_list" %>


  </div>
</div>