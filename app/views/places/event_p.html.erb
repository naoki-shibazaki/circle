<% set_meta_tags noindex: true, nofollow: true %>
<div class="main users-index">
  <div class="container">

    <%= render "/layouts/breadcrumb" %>
    <h1 class="users-heading">全国のコート情報一覧</h1>


	<div class="search_area">

		<div class="coat-container">

	  <div class="cp_actab">
	    <input id="tab-two" type="checkbox" name="tabs">
	    <label for="tab-two">
	      <i class="fa fa-search search-list"></i>47都道府県から探す
	    </label>
	    <div class="cp_actab-content">

	      <ul class="prefectures-menus place_meus">
	        <% @prefectures.each do |prefecture| %>
	          <% if prefecture.id != 50 %>        
	            
	            <% if prefecture.group != @x %>
	              <div class="prefectures-sub-title"><%= prefecture.group %>エリア</div>
	              	<li>
	                  <%= link_to "/places/#{@event.ruby}/#{prefecture.kana}" do %>
	                  	<%= prefecture.name %>（<%= @places_count.where(prefecture_id: prefecture.id).count %>）
	                  <% end %>
	              	</li> 

	              <% @x = prefecture.group %>
	              
	            <% else %>
	              	<li>
	                  <%= link_to "/places/#{@event.ruby}/#{prefecture.kana}" do %>
	                  	<%= prefecture.name %>（<%= @places_count.where(prefecture_id: prefecture.id).count %>）
	                  <% end %>
	              	</li> 
	            <% end %>
	          
	          <% end %>
	        <% end %> 
	      </ul> 

	    </div>
	  </div>

		</div>

	</div>


<% @places.each.with_index(1) do |place, i| %>


  <div class="users-index-item ribbon-wrapper">

      <div class="ribbon-content">
        <% if place.tag.to_i == 1 %>
          <span class="ribbon green">屋内</span>
        <% else place.tag.to_i == 2 %>
          <span class="ribbon blue">屋外</span>
        <% end %>
      </div>

      <div class="place_cnt_wrap">

          <h2 class="place_name"><%= place.name.truncate(24) %></h2>


      </div>

   

      <div class="border"></div>

      <div class="article_item article_padding place_list ">
        <table>
          <tbody>

            <tr class="flex_contents">
              <th class="flex_list">住所</th>
              <td class="flex_list"><%= place.address %></td>
            </tr>
            <tr class="flex_contents">
              <th class="flex_list">アクセス</th>
              <td class="flex_list"><%= place.access %></td>
            </tr>
            <tr class="flex_contents">
              <th class="flex_list">利用可能時間</th>
              <td class="flex_list"><%= raw Rinku.auto_link(simple_format place.time) %></td>
            </tr>
            <tr class="flex_contents">
              <th class="flex_list">定休日</th>
              <td class="flex_list"><%= raw Rinku.auto_link(simple_format place.regular_holiday) %></td>
            </tr>

          </tbody>
        </table> 
      </div>
      
      <%= link_to "詳細を確認する", "/places/all/#{place.prefecture.kana}/#{place.city.city_kana}/#{place.id}", class: "place_more" %>

  </div> <!-- 各フレーム -->

    <% if i == 5 %>
      <div class="list_ad">
        <%= render "/layouts/ad_square" %>
      </div>
    <% end %>

<% end %>

<%= render "/layouts/ad_square" %>

<%= paginate @places %>

  </div>
</div>