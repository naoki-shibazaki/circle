<div class="events-container">

  <div class="cp_actab">
    <input id="tab-one" type="checkbox" name="tabs">
    <label for="tab-one">趣味やスポーツ、団体から探す</label>
    <div class="cp_actab-content">

      <ul class="events-menus">
        <% @events.each do |event| %>

        <% if @category != event.category %>
          <div class="category-title">▼<%= event.category %></div>
          <% @category = event.category %>
        <% end %>

          <% if @path.is('blogs#index', 'blogs#top', 'blogs#prefecture_index') %>
              <li>
                <%= link_to("/blog/#{event.ruby}") do %>
                  <div class="e_icon_wrap">
                    <img src="/images/events/s_e_icon_<%= event.ruby %>.jpg" alt="<%= event.name %>">
                    <div class="link_txt"><%= event.name %></div>
                  </div>
                <% end %>
              </li> 
          <% else %>
              <li>
                <%= link_to("/blog/#{event.ruby}/#{@prefecture.kana}") do %>
                  <div class="e_icon_wrap">
                    <img src="/images/events/s_e_icon_<%= event.ruby %>.jpg" alt="<%= event.name %>" >
                    <div class="link_txt"><%= event.name %></div>
                  </div>
                <% end %>
              </li> 
          <% end %> 
          
        <% end %> 
      </ul> 

    </div>
  </div>

</div>