<div class="main users-new">
  <div class="container">
    <div class="form-heading">投稿の編集</div>
    <div class="form users-form">
      <div class="form-body cont-body">
        <% if @blog.errors.any? %>
            <div class="form-error">
              以下の項目でエラーが発生いたしました。<br>
              ※原因不明の場合は空欄でご登録ください
            </div>
        <% end %>

        <% @blog.errors.full_messages.each do |message| %>
            <div class="form-error_message">
              ・<%= message %>
            </div>
        <% end %>


      <%= render "form_blog.html.erb"%>

      </div>
    </div>
  </div>
</div>