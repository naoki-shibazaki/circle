<div class="main users-new">
  <div class="container">
    <div class="form-heading">ログイン</div>
    <div class="form users-form">
      <div class="form-body">

      <%= form_for(:session, url: login_path) do |f| %>

        <p>メールアドレス</p>
        <%= f.text_field :email, class: 'form-control'%>       

        <p>パスワード</p>
        <%= f.text_field :password, class: 'form-control'%>       

        <%= f.submit "ログイン" %>
        
      <% end %>

      </div>
    </div>
  </div>
</div>