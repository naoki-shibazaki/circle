<div class="search_wrap">	 

		<div class="search_select">

	        <% if @path.is('users#index', 'users#top', 'users#search') %>

					<select name="event_select" onChange="location.href=value;">
						<option value="#">サークル・団体</option>
					    <% @events.each do |event| %>
							<option value="/<%= event.ruby %>"><%= event.name %></option>
						<% end %>
					</select>

					<select name="prefecture_select" onChange="location.href=value;">
						<option value="#">都道府県</option>
					    <% @prefectures.each do |prefecture| %>
							<% if prefecture.id != 50 %>
								<option value="/prefectures/<%= prefecture.kana %>"><%= prefecture.name %></option>
							<% end %>
						<% end %>
					</select>

					<div class="search_icon"><i class="fa fa-search "></i></div>


	        <% elsif @path.is('users#event_prefecture') %>

					<select name="event_select" onChange="location.href=value;">
						<option value="#"><%= @event.name %></option>
					    <% @events.each do |event| %>
						    <% if event.ruby != @event.ruby %>
								<option value="/<%= event.ruby %>"><%= event.name %></option>
							<% end %>
						<% end %>
					</select>

					<select name="prefecture_select" onChange="location.href=value;">
						<option value="#"><%= @prefecture.name %></option>
					    <% @prefectures.each do |prefecture| %>					    
							<% if prefecture.id != 50 %>
							    <% if prefecture.kana != @prefecture.kana %>
									<option value="/<%= @event.ruby %>/<%= prefecture.kana %>"><%= prefecture.name %></option>
								<% end %>
							<% end %>
						<% end %>
					</select>

					<div class="search_icon"><i class="fa fa-search "></i></div>


	        <% elsif  @path.is('users#event') %>

					<select name="event_select" onChange="location.href=value;">
						<option value="#"><%= @event.name %></option>
					    <% @events.each do |event| %>
						    <% if event.ruby != @event.ruby %>
								<option value="/<%= event.ruby %>"><%= event.name %></option>
							<% end %>
						<% end %>
					</select>

					<select name="prefecture_select" onChange="location.href=value;">
						<option value="#">都道府県</option>
					    <% @prefectures.each do |prefecture| %>
							<% if prefecture.id != 50 %>
								<option value="/<%= @event.ruby %>/<%= prefecture.kana %>"><%= prefecture.name %></option>
							<% end %>
						<% end %>
					</select>

					<div class="search_icon"><i class="fa fa-search "></i></div>


			
			<% elsif @path.is('users#prefecture_city') %>


	        	<div class="search_select_3">

					<select name="event_select" onChange="location.href=value;">
						<option value="#">サークル</option>
					    <% @events.each do |event| %>
							<option value="/<%= event.ruby %>/<%= @prefecture.kana %>/<%= @city.city_kana %>"><%= event.name %></option>
						<% end %>
					</select>

					<select name="prefecture_select" onChange="location.href=value;">
						<option value="#"><%= @prefecture.name %></option>
					    <% @prefectures.each do |prefecture| %>
					   		<% if prefecture.id != 50 %>
							    <% if prefecture.kana != @prefecture.kana %>
									<option value="/prefectures/<%= prefecture.kana %>"><%= prefecture.name %></option>
								<% end %>
							<% end %>
						<% end %>
					</select>

					<select name="city_select" onChange="location.href=value;">
						<option value="#"><%= @city.name %></option>
					    <% @cities.each do |city| %>
							<% if city.city_kana != @city.city_kana %>
								<option value="/prefectures/<%= @prefecture.kana %>/<%= city.city_kana %>"><%= city.name %></option>
							<% end %>
						<% end %>
					</select>		

					<div class="search_icon"><i class="fa fa-search "></i></div>

				</div>

	        <% elsif @path.is('users#prefecture') %>

	        	<div class="search_select_3">

					<select name="event_select" onChange="location.href=value;">
						<option value="#">サークル</option>
					    <% @events.each do |event| %>
							<option value="/<%= event.ruby %>/<%= @prefecture.kana %>"><%= event.name %></option>
						<% end %>
					</select>

					<select name="prefecture_select" onChange="location.href=value;">
						<option value="#"><%= @prefecture.name %></option>
					    <% @prefectures.each do |prefecture| %>
					   		<% if prefecture.id != 50 %>
							    <% if prefecture.kana != @prefecture.kana %>
									<option value="/prefectures/<%= prefecture.kana %>"><%= prefecture.name %></option>
								<% end %>
							<% end %>
						<% end %>
					</select>

					<select name="city_select" onChange="location.href=value;">
						<option value="#">市区町村郡</option>
					    <% @cities.each do |city| %>
							<option value="/prefectures/<%= @prefecture.kana %>/<%= city.city_kana %>"><%= city.name %></option>
						<% end %>
					</select>		

					<div class="search_icon"><i class="fa fa-search "></i></div>

				</div>

			<% else %>

			<% end %>

		
	  	</div>

<!-- 修正 -->
<% if admin_user_signed_in? %>
	<% if current_admin_user.id == 1 %>
		<div class="sort_select">
		<%= form_tag('/users/search', method: :get) do %>
		   <input id="page_name" name='keyword' size="30" type="text" value="<%= params[:keyword] %>"/>
		     <%= submit_tag("Search") %>
		<% end %>
		</div>
	<% end %>
<% end %>
<!-- 修正 -->


	  	<div class="sort_select">
		  	<% if params[:sort] == "1" || params[:sort] == nil %>
				<span class="sort_btn selected">関連順</span>
			  	<!-- <a href="<%= request.path %>?sort=2" ><span class="sort_btn">人気順</span></a> -->
			  	<a href="<%= request.path %>?sort=3" ><span class="sort_btn">新着順</span></a>
		  	<% elsif params[:sort] == "2" %>
				<a href="<%= request.path %>?sort=1" ><span class="sort_btn">関連順</span></a>
			  	<span class="sort_btn selected">人気順</span>
				<a href="<%= request.path %>?sort=3" ><span class="sort_btn">新着順</span></a>
		  	<% else params[:sort] == "3" %>
				<a href="<%= request.path %>?sort=1" ><span class="sort_btn">関連順</span></a>
				<!-- <a href="<%= request.path %>?sort=2" ><span class="sort_btn">人気順</span></a> -->
			  	<span class="sort_btn selected">新着順</span>
		  	<% end %>
	  	</div>

</div>