              <% end %>
            </ul>


          </div>
          <label class="readmore-label" for="check2-2"></label>
      </div>

    </div>


    <div class="top_contents bg_yellow">

      <div class="top_heading">
          <h2 class="sub_title">コートや体育館、施設を探す</h2>

      </div>

      <div class="readmore">
          <input id="check3-1" class="readmore-check" type="checkbox">
          <div class="readmore-content">
            <ul class="events-menus">
              <% @place_events.each do |place_event| %>
                <li>
                  <%= link_to("/places/#{place_event.ruby}") do %>
                    <div class="e_icon_wrap">
                      <img data-src="/images/events/<%= place_event.ruby %>.jpg" alt="<%= place_event.name %>" class="lazyload">
                      <div class="link_txt"><%= place_event.name %></div>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
          <label class="readmore-label" for="check3-1"></label>
      </div>

    </div>



  </div>
</div>