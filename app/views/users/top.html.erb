    <img class="imege_title" src="/images/top.png">
    <h1 class="users-heading"><img class="img_logo_title" src="/images/logo.png" alt="サークルブック"></h1>
    <div class="users-txt">
          <% if admin_user_signed_in?  %>
            <%= link_to("活動ブログ", new_user_blog_path(@user) ) %>を投稿すると<br>
