<% set_meta_tags noindex: true,
				title: "マイページ"
%>

<div class="main users-index">
  <div class="container">

    <%= render "/layouts/breadcrumb" %>
    
	<div class="mypage_wrap">

	<div class="p_t">マイページ</div>


		<div class="user_select_wrap">
			現在のアカウント：
			<select name="user_select" onChange="location.href=value;">
				<option value="#"><%= @user.name %>（<%= @user.event.name %>）</option>
			    <% @admin_user.users.each do |user| %>
				    <% if @user.id != user.id %>
						<option value="/users/<%= user.id %>/mypage"><%= user.name %>（<%= user.event.name %>）</option>
				    <% end %>
				<% end %>
				<option value="/user/add">＋ サークルを追加する</option>
			</select>
		</div>


  		<%= render "/users/analytics" %>
	
		<div class="icon_wrap">

				<%= link_to user_path(@user), class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_01.png">
						</div>

						<div class="icon_txt">
							サークル確認
						</div>
					</div>
				<% end %>

				<%= link_to edit_user_path(@user), class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_02.png">
						</div>

						<div class="icon_txt">
							サークル編集
						</div>
					</div>
				<% end %>


				<%= link_to new_user_blog_path(@user), class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_03.png">
						</div>

						<div class="icon_txt">
							ブログ投稿
						</div>
					</div>
				<% end %>


				<%= link_to user_schedules_path(@user), class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_08.png">
						</div>

						<div class="icon_txt">
							スケジュール管理
						</div>
					</div>
				<% end %>



				<%= link_to user_questions_path(@user), class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
			                <% if @questions_current.count < 3 || @questions_current_nil.count >= 1 %>
			                	<div class="notice_icon">
			                <% else %>
			                	<div class="nil">            
			                <% end %>	
								<img class="icon_size" src="/images/icon/icon_06.png">
							</div>
						</div>

						<div class="icon_txt">
								質問コーナー
						</div>
					</div>
				<% end %>


				<%= link_to user_reviews_path(@user), class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_13.png">
						</div>

						<div class="icon_txt">
							口コミ・評価
						</div>
					</div>
				<% end %>



				<%= link_to "/user/add", class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_12.png">
						</div>

						<div class="icon_txt">
							サークルを追加
						</div>
					</div>
				<% end %>	



			<% if @user.event.matching != 0 %>


				<% if @user.match.present? %>
					<%= link_to match_path(@user), class: "icon_cont" do %>
						<div class="">
							<div class="icon_img">
								<img class="icon_size" src="/images/icon/icon_01.png">
							</div>

							<div class="icon_txt">
								対戦募集マイページ
							</div>
						</div>
					<% end %>
				<% end %>

				<%= link_to new_user_match_path(@user), class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_10.png">
						</div>

						<div class="icon_txt">
							対戦相手の募集
						</div>
					</div>
				<% end %>

				<%= link_to matches_path, class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_11.png">
						</div>

						<div class="icon_txt">
							対戦相手の一覧
						</div>
					</div>
				<% end %>


			<% end %>


				<%= link_to "/users", class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_07.png">
						</div>

						<div class="icon_txt">
							サークル検索
						</div>
					</div>
				<% end %>

				<%= link_to "/blog", class: "icon_cont" do %>
					<div class="">
						<div class="icon_img">
							<img class="icon_size" src="/images/icon/icon_09.png">
						</div>

						<div class="icon_txt">
							ブログ検索
						</div>
					</div>
				<% end %>

		</div>

		<%= render "/users/openchat" %>


	<div class="opinion_wrap">
		<div class="p_t opinion_title">ご意見箱</div>

		<div class="opinion_txt">
			どんな些細なことでも構いませんので、<br>
			サークルブックへのご意見をお聞かせください！
		</div>


            <%= form_for ([@user, @opinion]) do |f| %>

                <%= f.text_area :opinion, class: 'form-control form-note', placeholder: "「こんな機能があると便利！」「ここをこうして欲しい！」など。気軽にお書きください！" %> 

		        <div class="contact">
		        	>>返信が必要な場合は<a href="mailto:circlebook47@gmail.com?subject=【お問い合わせ】サークルブック｜<%= @user.name %> 様" >コチラ</a>から
		        </div>

           		<input type="submit" name="commit" value="送信する" data-disable-with="送信する">

            	<div class="reset"></div>

            <% end %>


	</div>

	</div>






<%= render "/layouts/ad_square" %>
<div class="ad_space"></div>


  </div>
</div>

