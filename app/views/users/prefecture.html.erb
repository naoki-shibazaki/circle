<% set_meta_tags title: "【#{@time.strftime("%Y")}年版】#{@prefecture.name}で活動しているメンバー募集中のサークル！",
                  description: "【登録不要・無料で使える！】#{@prefecture.name}で活動しているサークル！メンバー募集中です！社会人や学生、初心者、経験者など、誰でも参加可能！完全無料でサークル参加、メンバーの募集が簡単にできます！",
                   keywords: "#{@prefecture.name},サークル,チーム,募集"
 %>

<div class="main users-index">
  <div class="container">
 	<%= render "/layouts/breadcrumb" %>
    <h1 class="users-heading"><%= @prefecture.name %>のサークル一覧</h1>

	<% if @hit != 0 %>
		<div class="search_area">
			<%= render "/users/search.html.erb" %>

	    	<%= render "events_list.html.erb" %>
		</div>

		<%= render "users_list.html.erb" %>

	<% end %>

	<% if @hit == 0 %>
		<%= render "/users/no_hit.html.erb" %>
	<% end %>


    
  </div>
</div>