<% @user.reviews.last(3).reverse_each do |review| %>
  <div class="review_contents">
    <div class="review_l">

      <% if request.format == :amp %>
        <% if review.member.present? %>
          <% if review.member.image_profile.present? %>
            <amp-img src="<%= review.member.image_profile.url %>"
              class="member_icon"
              width="38"
              height="38"
              object-fit="cover">
            </amp-img>
          <% else %>
            <amp-img src="/images/icon/icon_member.png"
              class="member_icon"
              width="38"
              height="38"
              object-fit="cover">
            </amp-img>
          <% end %>
        <% else %>
            <amp-img src="/images/icon/icon_member.png"
              class="member_icon"
              width="38"
              height="38"
              object-fit="cover">
            </amp-img>
        <% end %>

      <% else %>
        <% if review.member.present? %>
          <% if review.member.image_profile.present? %>
            <%= lazysizes_image_tag review.member.image_profile.url , class:'member_icon' %>
          <% else %>
            <img src="/images/icon/icon_member.png" class="member_icon">
          <% end %>
        <% else %>
          <img src="/images/icon/icon_member.png" class="member_icon">
        <% end %>
      <% end %>
    </div>

    <div class="review_r">
      <div class="speech_title">
        <% if review.review == 1 %>
          <i class="fa fa-smile-o good"></i>
        <% elsif review.review == 0 %>
          <i class="fa fa-frown-o bad"></i>
        <% else %>

        <% end %>

        <% if review.member.present? %>
          <%= review.member.nickname  %>さん
        <% else %>
          名前なしさん
        <% end %>

        <% if review.member.present? %>
          <span class="random_id">（@<%= review.member.random_id %>）</span>
        <% end %>

      </div>
      <div class="speech_bubble">
        <%= simple_format review.comment.truncate(120) %>
      </div>
    </div>
  </div>
  <div class="reset"></div>

<% end %>

<div class="review_link_b"><%= link_to ">>口コミをもっと見る",user_reviews_path(@user) %></div>
