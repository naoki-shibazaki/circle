<div class="form-body cont-body">
  <% if @user.errors.any? %>
      <div class="form-error">
        以下の項目でエラーが発生いたしました。<br>
        ※原因不明の場合は空欄でご登録ください
      </div>
  <% end %>

  <% @user.errors.full_messages.each do |message| %>
      <div class="form-error_message">
        ・<%= message %>
      </div>
  <% end %>

<% if current_admin_user.id == 1 %>
  <div class="form">
    <%= form_for @admin_user, url:"/users/#{@user.id}/admin_user_update" do |f| %>
      <div class="label_item"><span class="label label_danger">管理権限</span>規約違反判定</div><br>
      <%= f.select :check, [ ['なし',''],['ネットワークビジネス',1], ['宗教',2] ] %>

      <%= f.submit "更新する", data: { disable_with: '更新中...' } %>
    <% end %>
  </div>
  <div class="reset"></div>
<% end %>


<%= form_for @user do |f| %>

  <div class="img_field_profile_wrap">

  <div class="label_item">プロフィール画像（アイコン＆背景写真）</div>
  <div id="img_field_header" onClick="$('#file_header').click()" >
    <% if @user.pic_header.present? %>
      <%= image_tag(@user.pic_header.url) %>
    <% else %>
      <i class="fa fa-image"></i>
    <% end %>
  </div>
  <%= f.file_field :pic_header, class: "image", style: "display:none;", id: "file_header"%>


  <div id="img_field_profile" onClick="$('#file_profile').click()" >
    <% if @user.pic_profile.present? %>
      <%= image_tag(@user.pic_profile.url) %>
    <% else %>
      <i class="fa fa-image"></i>
    <% end %>
  </div>
  <%= f.file_field :pic_profile, class: "image", style: "display:none;", id: "file_profile"%>

  <div class="file_size_p">※10MB以下のjpgかpngのみ対応</div>

</div>

<div class="img_field_profile_space"></div>


<% if @user.pic_profile.present? || @user.pic_header.present? %>
  <ul class="remove_img">
    <% if @user.pic_profile.present? %>
      <li><%= f.check_box :remove_pic_profile %>アイコン画像の削除</li>
    <% end %>

    <% if @user.pic_header.present? %>
      <li><%= f.check_box :remove_pic_header %>背景画像の削除</li>
    <% end %>
  </ul>
<% end %>

<% if current_admin_user.id == 1 %>
  <div class="label_item"><span class="label label_danger">管理権限</span>NGアカウント判定</div>
  <%= f.select :ng_account, [ ['OK', 'OK'], ['NG','NG'] ] %>
<% end %>

<% if @user.switch.present? %>
  <div class="label_item"><span class="label label_danger">必須</span>新規メンバーの募集</div>
  <%= f.select :switch, [ ['募集中','募集中'], ['受付終了','受付終了'] ] %>
<% end %>

<div class="label_item"><span class="label label_danger">必須</span>サークル名</div>
<%= f.text_field :name, class: 'form-control change_font', placeholder: "サークルブック" %>


<div class="label_item"><span class="label label_danger">必須</span>サークル種目（大）</div>
<% category_options = Category.order(:id).map { |e| [e.name, e.id, data: { children_path: category_events_path(e) }] } %>
<%= f.select :category_id, category_options, { include_blank: true }, class: 'user-select-parent' %>

<div class="label_item"><span class="label label_danger">必須</span>サークル種目（中）</div>
<% events = Event.where(category_id: @user.category).order(:users_count => :desc) %>
<% event_options = events.map { |e| [e.name, e.id] } %>
<%= f.select :event_id, event_options, { include_blank: true }, class: 'user-select-children' %>


<div class="label_item"><span class="label label_danger">必須</span>メインの活動エリア（例：東京都）</div>
<%= f.collection_select :prefecture_id, Prefecture.all.order(:order => :asc), :id, :name, :prompt => "選択してください" %>

<div class="label_item">サブの活動エリア（例：神奈川県）</div>
<%= f.collection_select :prefecture_sub_id, Prefecture.where.not(id: 50).order(:order => :asc), :id, :name, :include_blank => true %>

<div class="label_item">活動時間</div>
<%= f.text_field :schedule, class: 'form-control', placeholder: "月曜日 18〜20時" %>

<div class="label_item">活動場所</div>
<%= f.text_field :area, class: 'form-control', placeholder: "世田谷区周辺" %>

<div class="label_item">こんな人を探しています</div>
<%= f.text_field :recruitment, class: 'form-control', placeholder: "初心者・経験者でもOKです！" %>

<div class="label_item">現在の構成メンバー</div>
<%= f.text_field :member, class: 'form-control', placeholder: "10名程" %>

<div class="edit01_warp">
<span class="edit01_subtitle">年齢層</span>
  <div class="check_boxes">
    <%= f.collection_check_boxes(:age_ids, Age.all, :id, :name) %>
  </div>
</div>

<div class="edit01_warp">
  <span class="edit01_subtitle">募集内容</span>
    <div class="check_boxes">
      <%= f.collection_check_boxes(:group_ids, Group.all.order(:id => :asc), :id, :name) %>
    </div>
</div>

<div class="label_item">会費・費用</div>
<%= f.text_field :cost, class: 'form-control', placeholder: "500円" %>

<div class="label_item">サークル目標</div>
<%= f.text_field :goal, class: 'form-control', placeholder: "ゆくる、楽しく活動をする！" %>

<div class="label_item">LINEビジネス（LINE@）／LINEのURL</div>
<a href="/line" target="_blank" class="line_id"> >>30秒で作れるLINEアカウントの追加方法</a>
<%= f.text_field :line_id, class: 'form-control', placeholder: "http://nav.cx/3JiS9Im" %>

<% if @user.line_id.present? %>
  <div class="label_item">連絡方法</div>
  <%= f.select :contact, [ ['メール＆LINE','both'], ['LINEのみ','line'] , ['メールのみ','mail'] ] %>
<% end %>


<div class="sns_form">
  <div class="label_item">Twitter ID</div>
  <div class="sns_input">
    <span class="atmark">@</span><%= f.text_field :twitter, class: 'form-control', placeholder: "circle_book_" %>
  </div>
</div>

<div class="sns_form">
  <div class="label_item">Instagram ID</div>
  <div class="sns_input">
    <span class="atmark">@</span><%= f.text_field :instagram, class: 'form-control', placeholder: "circlebook47" %>
  </div>
</div>


<div class="reset"></div>


<div class="label_item">ホームページ</div>
<%= f.text_field :web, class: 'form-control', placeholder: "https://www.circle-book.com/" %>

<div class="edit01_warp">
  <span class="edit01_subtitle">サークル画像（最大4枚）</span>

  <div class="file_upload_wrap">
    <span class="file_size">※10MB以下のjpgかpngのみ対応</span>
    <div class="img_field_gallery_wrap">

      <div id="img_field_01" onClick="$('#file_01').click()" >
          <% if @user.gallery_01.present? %>
            <%= image_tag(@user.gallery_01.url) %>
          <% else %>
            <i class="fa fa-image"></i>
          <% end %>
      </div>
      <%= f.file_field :gallery_01, class: "image", style: "display:none;", id: "file_01"%>


      <div id="img_field_02" onClick="$('#file_02').click()" >
          <% if @user.gallery_02.present? %>
            <%= image_tag(@user.gallery_02.url) %>
          <% else %>
            <i class="fa fa-image"></i>
          <% end %>
      </div>
      <%= f.file_field :gallery_02, class: "image", style: "display:none;", id: "file_02"%>


      <div id="img_field_03" onClick="$('#file_03').click()" >
          <% if @user.gallery_03.present? %>
            <%= image_tag(@user.gallery_03.url) %>
          <% else %>
            <i class="fa fa-image"></i>
          <% end %>
      </div>
      <%= f.file_field :gallery_03, class: "image", style: "display:none;", id: "file_03"%>


      <div id="img_field_04" onClick="$('#file_04').click()" >
          <% if @user.gallery_04.present? %>
            <%= image_tag(@user.gallery_04.url) %>
          <% else %>
            <i class="fa fa-image"></i>
          <% end %>
      </div>
      <%= f.file_field :gallery_04, class: "image", style: "display:none;", id: "file_04"%>

    </div>
  </div>

  <% if @user.gallery_01.present? || @user.gallery_02.present? || @user.gallery_03.present? || @user.gallery_04.present? %>
    <ul class="remove_img">
      <% if @user.gallery_01.present? %>
        <li><%= f.check_box :remove_gallery_01 %>①削除</li>
      <% end %>

      <% if @user.gallery_02.present? %>
        <li><%= f.check_box :remove_gallery_02 %>②削除</li>
      <% end %>

      <% if @user.gallery_03.present? %>
        <li><%= f.check_box :remove_gallery_03 %>③削除</li>
      <% end %>

      <% if @user.gallery_04.present? %>
        <li><%= f.check_box :remove_gallery_04 %>④削除</li>
      <% end %>
    </ul>
  <% end %>

</div>

  <div class="label_item">サークルの詳細情報</div>
  <div class="rich_text_sub">
    <%= f.hidden_field :appeal, id: :article_text %>
    <trix-editor input="article_text" placeholder= "サークルブックは週１回、都内で活動しています！興味がある人は気軽にご連絡ください！"></trix-editor>
  </div>

  <% if @path.is('users#edit') %>
    <div class="warning_txt">※更新完了に少し時間がかかります</div>
    <%= f.submit "更新する", data: { disable_with: '更新中...' } %>
  <% elsif @admin_user.check.present? && @admin_user.check != 0 %>
    <br>
    <div class="attention_content"><i class="fa fa-warning "></i>
      このアカウントは一時的に制限されています
    </div>
  <% else %>
    <div class="warning_txt">※更新完了に少し時間がかかります</div>
    <%= f.submit "更新する", data: { disable_with: '更新中...' } %>
  <% end %>

<% end %>

</div>