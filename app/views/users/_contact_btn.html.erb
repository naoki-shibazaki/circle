<% if @user.admin_user.check == 1 %>

  <div class="contact_link">
    <%= link_to new_user_user_contact_path(@user, check: "1") do %>
      <div class="btn btn_c btn_green btn_cubic">
        <i class="fa fa-envelope"></i>このサークルに参加する！
      </div>
    <% end %>
  </div>

  <div class="contact_link">
    <%= link_to new_user_user_contact_path(@user, entry: "1", check: "1") do %>
      <div class="btn btn_c btn_green btn_cubic">
        <i class="fa fa-star"></i>見学してみる！
      </div>
    <% end %>
  </div>


<% else %>

  <div class="contact_link">
    <%= link_to new_user_user_contact_path(@user) do %>
      <div class="btn btn_c btn_green btn_cubic">
        <i class="fa fa-envelope"></i>このサークルに参加する！
      </div>
    <% end %>
  </div>

  <div class="contact_link">
    <%= link_to new_user_user_contact_path(@user, entry: "1") do %>
      <div class="btn btn_c btn_green btn_cubic">
        <i class="fa fa-star"></i>見学してみる！
      </div>
    <% end %>
  </div>


<% end %>