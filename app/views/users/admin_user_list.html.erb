<% set_meta_tags noindex: true %>

<div class="main users-index">
  <div class="container">

    <div class="table_list">
      <table>
        <tr><th>AdminUser</th><th>User</th><th>Name</th></tr>

        <% @admin_users.reverse_each do |admin_user| %>
          <% admin_user.users.each do |user| %>
            <tr>
              <td><%= admin_user.id %></td>
              <td><%= user.id %></td>
              <td><%= link_to user.name, "/users/#{user.id}"%>
            </tr>
          <% end %>
        <% end %>
      </table>

    </div>

  </div>
</div>

