<script type="application/ld+json">
{
  "@context": "http://schema.org/",
  "@type": "LocalBusiness",
  "@id": "<%= request.path %>",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "JP",
    "addressRegion": "<%= user.prefecture.name %>"
  },
  "name": "<%= user.name %>",
  "description": "<%= user.prefecture.name %>で活動している<%= user.event.txt %>",
  "image": [
    "<%= user.pic_profile.url %>",
    "<%= user.pic_header.url %>"
  ],
  "priceRange": "<%= user.cost %>"
}
</script>

<script type="application/ld+json">
{
"@context": "https://schema.org",
"@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem",
    "position": 1,
    "name": "サークルブック",
    "item": "https://www.circle-book.com"
  },{
    "@type": "ListItem",
    "position": 2,
    "name": "<%= user.event.name %>",
    "item": "https://www.circle-book.com/<%= user.event.ruby %>"
  },{
    "@type": "ListItem",
    "position": 3,
    "name": "<%= user.prefecture.name %>",
    "item": "https://www.circle-book.com/<%= user.event.ruby %>/<%= user.prefecture.kana %>"
  },{
    "@type": "ListItem",
    "position": 4,
    "name": "<%= user.name %>",
    "item": "https://www.circle-book.com/users/<%= user.id %>"
  }]
}
</script>

<% if user.questions.present? %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    <% user.questions.each.with_index(1) do |question, i| %>
      <%= "," if i > 1 %>{
        "@type": "Question",
        "name": "<%= question.content %>",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "<%= question.answer %>"
        }
      }
    <% end %>
  ]
}
</script>
<% end %>