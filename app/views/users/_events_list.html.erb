<div class="events-container">
  <div onclick="obj=document.getElementById('open_e').style; obj.display=(obj.display=='none')?'block':'none';">
    <a style="cursor:pointer;"><h2 class="events-title">趣味やスポーツから探す</h2></a>
  </div>  

  <div id="open_e" style="display:none;clear:both;">  
    <ul class="events-menus">
      <% @events.each do |event| %>

        <% if @path.is('users#index', 'users#top') %>
            <li>
              <%= link_to("/events/#{event.ruby}") do %>
                <i class="<%= event.icon %>"></i> 
                <div class="link_txt"><%= event.name %></div>
              <% end %>
            </li> 
        <% else %>
            <li>
              <%= link_to("/#{event.ruby}/#{@prefecture.kana}") do %>
                <i class="<%= event.icon %>"></i> 
                <div class="link_txt"><%= event.name %></div>
              <% end %>
            </li> 
        <% end %> 
        
      <% end %> 
    </ul> 
  </div>

</div>

        