<% set_meta_tags noindex: true %>

<div class="main users-index">
  <div class="container">
  <div class="users-index-item">
    <div class="p_t">サークルブックへの報告</div>

      <div class="form">
        <%= form_for ([@user, @user_contact]) do |f| %>

          <p>▼ 違反内容を教えてください</p>
          <%= f.text_area :violation, class: 'form-control form-note', placeholder: "例）マルチ商法（ネットワークビジネス）の勧誘を目的としたサークルでした。
何回かサークルに参加後、ホームパーティーに呼ばれて勧誘されました。" %>

          <div class="reset"></div>

          <%= f.submit "報告する", data: { disable_with: '送信中...' } %>

        <% end %>
      </div>

    </div>
  </div>
</div>