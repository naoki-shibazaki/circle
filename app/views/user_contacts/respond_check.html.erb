<% set_meta_tags noindex: true %>

<div class="main users-index">
  <div class="container">
  <div class="users-index-item">
    <div class="p_t">サークルブックへの報告</div>
      <%= render "users/parts/user_name", user: @user%>

      <div class="form">
        <%= form_for ([@user, @user_contact]) do |f| %>

          <p>主催者からの返信はありましたか？</p>
          <%= f.select :respond_check, [ ['返信あり','OK'], ['返信なし','NG'] ],
          :prompt => "選択してください" %>

          <div class="reset"></div>

          <%= f.submit "報告する", data: { disable_with: '送信中...' } %>

        <% end %>
      </div>

    </div>
  </div>
</div>