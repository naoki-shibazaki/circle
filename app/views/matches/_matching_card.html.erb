	<% if admin_user_signed_in? %>

		<% if @match.user.admin_user_id != @admin_user.id %>
			
			<div class="vs_wrap">VS</div>
			<div class="matching_card">
			      <% if @admin_user.users.first.pic_profile.present? %>
			        <img src="<%= @admin_user.users.first.pic_profile.url %>" alt="プロフィール｜<%= @admin_user.users.first.name %>" class="matching_icon" />
			      <% else %>
			        <%= lazysizes_image_tag @admin_user.users.first.pic_profile.url , class:'matching_icon' %>
			      <% end %>

			      <div class="matching_name"><%= @admin_user.users.first.name %></div>
			</div>

				<%= link_to("/matches/#{@match.id}/contact") do %>
					<div class="matching_entry">
						練習試合を申し込む！
					</div>
				<% end %>


		<% end %>

	<% else %>

        <%= link_to(new_admin_user_registration_path) do %>
        	<div class="vs_wrap">VS</div>
			<div class="matching_entry">
				無料登録をして<br>
				練習試合を申し込む！
			</div>
        <% end %>


	<% end %>

