<% set_meta_tags title: "#{@event_question.question}｜#{@event.name}の質問コーナー",

				og: { 
					title: "#{@event.name}の質問コーナーです！",
					description: "", 
					image: "https://res.cloudinary.com/hgvtbyy8v/image/upload/l_text:Sawarabi%20Gothic_60:#{@event_question.question},y_-35,co_rgb:333333,w_900,c_fit/v1586676520/qa_vipkmx.jpg"
				},

				twitter: { card: 'summary_large_image'} 
%>


<div class="main users-index">
  <div class="container bg_white">
  	    <%= render "/layouts/breadcrumb" %> 

		<%= link_to "/#{@event.ruby}/qa/" do %>
		    <h1 class="users-heading"><%= @event.name %>の質問コーナー</h1>
		<% end %>

	<div class="ribbon-wrapper qa_card_img">
		<img src="https://res.cloudinary.com/hgvtbyy8v/image/upload/l_text:Sawarabi%20Gothic_60:<%= @event_question.question %>,y_-35,co_rgb:333333,w_900,c_fit/v1586676520/qa_vipkmx.jpg" alt="<%= @event_question.question %>">	
	</div>



	<div class="qa_wrap">

		<% if member_signed_in? %> 

			<% if current_member.id == 1 %>
				<div class="post_delete">
				    <%= link_to("/#{@event.ruby}/qa/#{@event_question.id}", method: :delete, data: {confirm: "投稿を削除しますか？"}) do %>質問を削除する									    
				    <% end %>
				</div>
			<% end %>


			<div class="qa_answer_form event_qa_answer_form">
				<%= form_for ([@event_question, @event_answer]), :url => { :controller => :event_answers, :action => :create }  do |f| %>

					<%= f.hidden_field :member_id, :value => current_member.id %> 

					<%= f.text_area :answer, class: 'form-control form-note', placeholder: "回答を書いてください！" %>

						<input type="submit" name="commit" value="回答する！" data-disable-with="回答する！" class="submit_btn">

					<div class="reset"></div>

				<% end %>
		 	 </div>	


		<% else %>
			  <%= link_to "この質問に答える！", new_member_registration_path, class: 'member_add_btn' %>

		<% end %>

	</div>





	 	 <% @event_question.event_answers.reverse.each do |event_answer| %>

			<% if event_answer.answer.present? %>

				 <% @members.each do |member| %>

				 	<% if member.id == event_answer.member_id %>


						<div class="event_anser_card">

						    <div class="user-content">


								<% if member.image_profile.present? %>
						        	<%= image_tag member.image_profile.url , class:'image_icon' %>
								<% else %>
									<img class="image_icon" src="/images/default.png">
						        <% end %>
							
						      <div class="list_wrapper contact_name_wrap">
						        <div class="list_01">

								<% if member.nickname.present? %>
						        	<h2 class="user_name"><%= member.nickname %></h2>
								<% else %>
									<h2 class="user_name">ニックネームなし</h2>
						        <% end %>
						        

						        </div>

						      </div>
						    </div> 

							<%= raw Rinku.auto_link(simple_format event_answer.answer) %>

						</div>


				 	<% end %>

				 <% end %>

	 	 	<% end %>

		<% end %>
	


  </div>
</div>