<% if @path.is('users#show') || @path.is('blogs#show') || @path.is('blogs#user_blogs') || @path.is('schedules') || @path.is('reviews#index') %>
  <div class="user_header_wrap">
    <ul class="user_header_menue">
      <li class="w10per"><span class="back_btn"><%= link_to "←", :back %></span></li>
      <li class="w10per"><span class="back_btn"><%= link_to(users_path) do %><i class="fa fa-home"></i><% end %></span></li>
      <li><span><%= link_to @user.name.truncate(24), user_path(@user) %></span><li>
    </ul>
    <ul class="header_menue_btm">
      <% if @path.is('users') %>
        <li class="current_page"><span><%= link_to "トップ", user_path(@user) %></span></li>
      <% else %>
        <li><span><%= link_to "トップ", user_path(@user) %></span></li>
      <% end %>

      <% if @path.is('blogs') %>
        <li class="current_page"><span><%= link_to "活動ブログ", user_blogs_path(@user) %></span></li>
      <% elsif @user.blogs.present? %>
        <li><span><%= link_to "活動ブログ", user_blogs_path(@user) %></span></li>
      <% else %>
        <li class="none_page"><span>活動ブログ</span></li>
      <% end %>

      <% if @path.is('schedules') %>
        <li class="current_page"><span><%= link_to "スケジュール", user_schedules_path(@user) %></span></li>
      <% elsif @user.schedules.present? %>
        <li><span><%= link_to "スケジュール", user_schedules_path(@user) %></span></li>
      <% else %>
        <li class="none_page"><span>スケジュール</span></li>
      <% end %>

      <% if @path.is('reviews') %>
        <li class="current_page"><span><%= link_to "口コミ", user_reviews_path(@user) %></span></li>
      <% elsif @user.reviews.present? %>
        <li><span><%= link_to "口コミ", user_reviews_path(@user) %></span></li>
      <% else %>
        <li class="none_page"><span>口コミ</span></li>
      <% end %>
    </ul>
  </div>

<% else %>
  <div class="header_wrap">
    <ul class="header-menus_sp">
      <!-- ログイン時の処理 -->
      <% if member_signed_in?  %>
        <li>
          <%= link_to(users_path) do %>
            <i class="fa fa-search "></i>
            <div class="link_txt">サークル検索</div>
          <% end %>
        </li>
        <li>
          <%= link_to("/blog") do %>
            <i class="fa fa-book "></i>
            <div class="link_txt">活動ブログ</div>
          <% end %>
        </li>
        <li>
          <%= link_to(member_path(current_member)) do %>
              <i class="fa fa-user"></i>
              <div class="link_txt">マイページ</div>
          <% end %>
        </li>
      <% elsif admin_user_signed_in?  %>
        <% if current_admin_user.users.any? %>
          <li>
            <%= link_to "/users/#{current_admin_user.users.first.id}/mypage" do %>
              <i class="fa fa-user notice_icon"></i>
              <div class="link_txt">マイページ</div>
            <% end %>
          </li>
        <% end %>

          <li>
            <%= link_to(users_path) do %>
              <i class="fa fa-search "></i>
              <div class="link_txt">サークル検索</div>
            <% end %>
          </li>
          <li>
            <%= link_to("/blog") do %>
              <i class="fa fa-book "></i>
              <div class="link_txt">活動ブログ</div>
            <% end %>
          </li>

      <!-- ログインなし -->
      <% else %>
        <li>

          <% if @path.is('matches') %>
            <%= link_to(matches_path) do %>
              <i class="fa fa-flag-checkered "></i>
              <div class="link_txt">対戦相手募集</div>
            <% end %>
          <% else %>
            <%= link_to(users_path) do %>
              <i class="fa fa-search "></i>
              <div class="link_txt">サークル検索</div>
            <% end %>
          <% end %>
        </li>
        <li>
          <%= link_to("/blog") do %>
            <i class="fa fa-book "></i>
            <div class="link_txt">活動ブログ</div>
          <% end %>
        </li>
        <li>
          <%= link_to(new_admin_user_registration_path) do %>
            <i class="fa fa-user-plus "></i>
            <div class="link_txt">サークル登録</div>
          <% end %>
        </li>
        <li>
          <%= link_to(login_path) do %>
            <i class="fa fa-sign-in "></i>
            <div class="link_txt">ログイン</div>
          <% end %>
        </li>

      <% end %>
      <%= render "/layouts/menu" %>
    </ul>
  <div>
<% end %>