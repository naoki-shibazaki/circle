        </a>
      </div>
    <% else %>
      <div class="footer_btn bg_btn">
        <a href="mailto:<%= @data.email %>?subject=<%= @mail_title %>&amp;body=<%= @mail_message %>">
          <span class="fixed_btn_b mail">このサークルにメールで相談する！</span>
        </a>
      </div>
    <% end %>
  <% end %>


  <% if admin_user_signed_in? && controller.action_name != 'show'  %>

