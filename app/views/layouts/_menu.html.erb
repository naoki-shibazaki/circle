<li>
    <div id="nav-drawer">
        <input id="nav-input" type="checkbox" class="nav-unshown">
        <label id="nav-open" for="nav-input"><span></span></label>
        <label class="nav-unshown" id="nav-close" for="nav-input"></label>
        <div id="nav-content">
          <div class="logo_txt">
            <%= link_to root_path do %>
              <img class="img_logo_memu" src="/images/logo.png" alt="サークルブック">
            <% end %>  
          </div>


          <% if member_signed_in?  %>

            <ul>
                <li><%= link_to 'マイページ', member_path(current_member)%></li>
                <li><%= link_to 'アカウント編集', edit_member_path(current_member)%></li>
            </ul>


          <% elsif admin_user_signed_in?  %>

            <ul>
                <li><%= link_to 'マイページ', "/users/#{current_admin_user.users.first.id}/mypage" %></li>
            </ul>

          <% else %>

            <div class="menu_btn"><%= link_to 'サークル登録', new_admin_user_registration_path %></div>
            <div class="menu_btn"><%= link_to 'ログイン', new_admin_user_session_path %></div>
            
          <% end %>


          <ul>
            <li><%= link_to 'バスケコート情報', '/places/basketball' %></li>
            <li><%= link_to 'よくある質問', '/faq' %></li>
            <li><%= link_to '利用規約', '/rules' %></li>
            <li><%= link_to 'プライバシーポリシー', '/privacypolicy' %></li>
          </ul>


          <% if member_signed_in?  %> 
            <ul>
                <li><%= link_to 'ログアウト', destroy_member_session_path, method: :delete %></li>

                <li><%= link_to 'ログイン情報の変更', edit_member_registration_path %></li>
            </ul>
          <% elsif admin_user_signed_in?  %>
            <ul>
                <li><%= link_to 'ログアウト', destroy_admin_user_session_path, method: :delete %></li>

                <li><%= link_to 'ログイン情報の変更', edit_admin_user_registration_path %></li>
            </ul>
          <% end %>          

          <ul>
            <li><a href="http://nav.cx/3JiS9Im">お問い合わせ（LINE@）</a></li>
            <li><a href="mailto:circlebook47@gmail.com?subject=【お問い合わせ】サークルブック" >お問い合わせ（メール）</a></li>
          </ul>

        </div>
    </div>
    <div class="link_txt">メニュー</div>
</li>