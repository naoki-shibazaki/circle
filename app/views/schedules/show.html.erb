<% if @schedule.top_image.present? %>
  <% set_meta_tags title: @meta_title,
            description: @meta_description,
            og: {image: @schedule.top_image.url},
            twitter: { card: 'summary_large_image'}
  %>
<% else %>
  <% set_meta_tags title: @meta_title,
            description: @meta_description,
            og: {image: image_url("/images/schedule_ogp.jpg")},
            twitter: { card: 'summary_large_image'}
  %>
<% end %>




<div class="user_main users-index ad_bottom_space">
  <div class="container">

    <%= render "/schedules/show_detail" %>

  </div>
</div>



