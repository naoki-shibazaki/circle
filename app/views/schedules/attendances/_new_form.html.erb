<div class="attendances_modal">
  <div id="attendance_add" class="modal js-modal">
    <div class="modal_bg js-modal-close"></div>

    <div class="modal_content">

      <div class="form-body cont-body form">
        <%= form_for(@name, url: "/schedules/#{@user.unique_id}", html: {method: 'get'}) do |f| %>
          <div class="label_item">名前</div><br>
          <%= f.text_field :name, class: 'form-control', placeholder: "ヤマダ" %>

          <% @schedules.each do |schedule| %>
            <%= f.fields_for :name_schedules do |name_schedule| %>
              <div class="label_item"><%= schedule.day %></div><br>
              <%= name_schedule.select :answer, [ ['◯ 参加', 1], ['× 不参加', 0]],
                  :prompt => "選択してください"  %>
              <%= name_schedule.text_field :comment, class: 'form-control', placeholder: "コメント" %>
              <%= name_schedule.hidden_field :schedule_id, value: schedule.id %>
            <% end %>
          <% end %>

          <%= f.submit "更新する", data: { disable_with: '更新中...' } %>
        <% end %>
      </div>

      <br><a class="js-modal-close" href="">閉じる</a>
    </div>
  </div>
</div>