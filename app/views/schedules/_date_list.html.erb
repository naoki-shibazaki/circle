<% if admin_user_signed_in?  %>
  <div class="post_message">
      <%= link_to(user_path(@user)) do %>
        <%= lazysizes_image_tag @user.pic_profile.url , class:'post_image_icon' %>
      <% end %>

      <%= link_to(new_user_schedule_path(@user)) do %>
        <div class="post_link">スケジュールを追加する！</div>
      <% end %>
  </div>
<% end %>



<% if @schedules.present? %>

  <ul>
    <% @schedules.each.with_index(1) do |schedule, i| %>

      <li class="schedule_item_wrap">

        <%= link_to(user_schedule_path(schedule.user.id, schedule.id)) do %>
          <div class="header_schedule_list ribbon-wrapper">
            <div class="header_img_wrap">
              <% if schedule.top_image.present? %>
                <%= lazysizes_image_tag schedule.top_image.url , class:'header_imege_user_list', alt: "#{schedule.title}" %>
              <% elsif schedule.user.pic_header.present? %>
                <%= lazysizes_image_tag schedule.user.pic_header.url , class:'header_imege_user_list', alt: "#{schedule.user.name}" %>
              <% else %>
                <%= lazysizes_image_tag schedule.user.pic_header.url , class:'header_imege_user_list' %>
              <% end %>
            </div>

            <div class="ribbon-content">
              <% if schedule.recruitment == "募集終了" %>
                <span class="ribbon red">満員御礼</span>
              <% elsif schedule.recruitment == "中止" %>
                <span class="ribbon yellow">中止</span>
              <% else %>
                <% if schedule.recruitment_numbers == 0 || schedule.recruitment_numbers.blank? %>
                  <span class="ribbon green">募集中</span>
                <% elsif schedule.name_schedules.where(answer: 1).count >= schedule.recruitment_numbers %>
                  <span class="ribbon red">満員御礼</span>
                <% else %>
                  <span class="ribbon green">募集中</span>
                <% end %>
              <% end %>
            </div>

          </div>


          <div class="schedule_list_content">
            <h2 class="schedule_list_title"><%= schedule.user.event.name %><%= "｜#{schedule.title}" if schedule.title.present? %></h2>

            <div class="schedule_cont">
                <div class="user_area">
                  <i class="fa fa-calendar icon_c"></i><%= Time.parse(schedule.day).strftime("%-m月%-d日(#{%w(日 月 火 水 木 金 土)[Time.parse(schedule.day).wday]})") %>
                  <% if schedule.time_s.present? %>
                    <%= schedule.time_s.strftime('%H:%M') %>
                    〜
                    <%= schedule.time_e.strftime('%H:%M') if schedule.time_e.present? %>
                  <% end %>

                </div>
                <div class="user_schedule">
                  <i class="fa fa-map-marker icon_c"></i><%= schedule.user.prefecture.name %><% if schedule.user.prefecture_sub_id.present? %>・<%= Prefecture.find(schedule.user.prefecture_sub_id).name %><% end %>：<%= schedule.venue %>
                </div>
            </div>

          </div>

        <% end %>

        <hr class="hr_w">


        <%= link_to(user_path(schedule.user.id)) do %>
          <div class="schedule_user_wrap">
            <div class="schedule_list_sub_title">主催サークル</div>

            <div class="user_profile_wrap">
                <%= lazysizes_image_tag schedule.user.pic_profile.url , class:'image_icon' %>
                <div class="user_profile">
                  <h3 class="user_name"><%= schedule.user.name.truncate(40) %></h3>
                </div>

              <div class="reset"></div>
            </div>
          </div>
        <% end %>


        <%= render "/users/parts/tag_list", user: schedule.user %>

      </li>

      <% if i == 5 || i == 10 || i == 15 %>
        <div class="list_ad">
          <%= render "/layouts/ad_square" %>
        </div>
      <% end %>

    <% end %>
  </ul>


  <%= render "/layouts/ad_square" %>

  <%= paginate @schedules %>

<% else %>

  <div class="no_hit_wrap">

    <img class="imege_sorry" src="/images/sorry.png">

    <%= link_to(root_path) do %>
      <div class="no_hit_top">トップページに戻る</div>
    <% end %>

    <%= link_to(new_admin_user_registration_path) do %>
      <div class="no_hit_new">新しくサークルを登録する</div>
    <% end %>

  </div>

  <%= render "/layouts/ad_square" %>
  <div class="ad_space"></div>

<% end %>