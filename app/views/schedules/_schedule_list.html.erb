<% if @schedules.where.not(id: @schedule.id).present? && params[:page] == nil %>

  <div class="schedule_list_wrap">

      <% @schedules.each do |schedule| %>
          <% if schedule.present? && @schedule.id != schedule.id %>

            <% if @schedule_month != Time.parse(schedule.day).strftime("%-m") %>
              <h2 class="schedule_m"><i class="fa fa-calendar "></i> <%= Time.parse(schedule.day).strftime("%-m月") %>のスケジュール</h2>
              <% @schedule_month = Time.parse(schedule.day).strftime("%-m") %>
            <% end %>

            <%= link_to(user_schedule_path(@user.id, schedule.id)) do %>

              <div class="schedule_list">
                  <div class="schedule_day">
                    <%= Time.parse(schedule.day).strftime("%-m月%-d日(#{%w(日 月 火 水 木 金 土)[Time.parse(schedule.day).wday]})") %>

                    <% if schedule.time_s.present? %>
                      <%= schedule.time_s.strftime('%H:%M') %>-<%= schedule.time_e.strftime('%H:%M') if schedule.time_e.present? %>
                    <% end %>

                    <% if schedule.recruitment == "募集終了" %>
                      <span class="schedule_mark mark_red">満員御礼</span>
                    <% elsif schedule.recruitment == "中止" %>
                      <span class="schedule_mark mark_yellow">中止</span>
                    <% else %>

                      <% if schedule.recruitment_numbers == 0 || schedule.recruitment_numbers.blank? %>
                        <div class="schedule_mark mark_green">募集中</div>
                      <% elsif schedule.name_schedules.where(answer: 1).count >= schedule.recruitment_numbers %>
                        <div class="schedule_mark mark_red">満員御礼</div>
                      <% else %>
                        <div class="schedule_mark mark_green">募集中</div>
                      <% end %>

                    <% end %>
                  </div>

                  <div class="schedule_venue">
                    <i class="fa fa-map-marker "></i> <%= schedule.venue %>
                  </div>
                  <div class="schedule_member">
                    <% if schedule.recruitment_numbers.present? %>
                      <% if schedule.recruitment_numbers == 0 %>
                        <i class="fa fa-users "></i> 募集人数：制限なし
                      <% elsif schedule.name_schedules.where(answer: 1).count == 0 %>
                        <i class="fa fa-users "></i> 募集人数：<%= schedule.recruitment_numbers %>名
                      <% elsif schedule.recruitment_numbers >= 1 %>
                        <i class="fa fa-users "></i> 参加人数：<%= schedule.name_schedules.where(answer: 1).count %><span class="small_font">/<%= schedule.recruitment_numbers %>名</span>
                      <% else %>
                        <i class="fa fa-users "></i> 参加人数：<%= schedule.name_schedules.where(answer: 1).count %>名
                      <% end %>
                    <% elsif schedule.name_schedules.where(answer: 1).count == 0 %>

                    <% else %>
                      <i class="fa fa-users "></i> 参加人数：<%= schedule.name_schedules.where(answer: 1).count %>名
                    <% end %>
                  </div>

                  <% if schedule.title.present? %>
                    <div class="schedule_title_list">
                      <%= schedule.title %>
                    </div>
                  <% end %>

              </div>

            <% end %>

          <% end %>
      <% end %>

  </div>

<% end %>

<% if params[:page] == nil %>
	<%= render "/layouts/ad_square" %>
	<div class="ad_space"></div>
<% end %>



<% if @past_schedules.where.not(id: @schedule.id).present? %>

  <h2 class="past_schedule">開催が終了したスケジュール</h2>

  <div class="schedule_list_wrap">

      <% @past_schedules.each do |past_schedule| %>
          <% if past_schedule.present? && @schedule.id != past_schedule.id %>
            <% if @past_schedule_month != Time.parse(past_schedule.day).strftime("%-m") %>

              <h3 class="schedule_m"><i class="fa fa-calendar "></i> <%= Time.parse(past_schedule.day).strftime("%Y年%-m月") %></h3>
              <% @past_schedule_month = Time.parse(past_schedule.day).strftime("%-m") %>
            <% end %>


              <%= link_to(user_schedule_path(@user.id, past_schedule.id)) do %>

                <div class="schedule_list">
                    <div class="schedule_day">
                        <%= Time.parse(past_schedule.day).strftime("%-m月%-d日(#{%w(日 月 火 水 木 金 土)[Time.parse(past_schedule.day).wday]})") %>

                      <% if past_schedule.time_s.present? %>
                        <%= past_schedule.time_s.strftime('%H:%M') %>-<%= past_schedule.time_e.strftime('%H:%M') if past_schedule.time_e.present? %>
                      <% end %>
                      <span class="schedule_mark mark_gray">開催終了</span>
                    </div>

                  <div class="schedule_venue">
                    <i class="fa fa-map-marker "></i> <%= past_schedule.venue %>
                  </div>
                  <div class="schedule_member">
                    <% if past_schedule.recruitment_numbers.present? %>
                      <% if past_schedule.recruitment_numbers == 0 %>
                        <i class="fa fa-users "></i> 募集人数：制限なし
                      <% elsif past_schedule.name_schedules.where(answer: 1).count == 0 %>
                        <i class="fa fa-users "></i> 募集人数：<%= past_schedule.recruitment_numbers %>名
                      <% elsif past_schedule.recruitment_numbers >= 1 %>
                        <i class="fa fa-users "></i> 参加人数：<%= past_schedule.name_schedules.where(answer: 1).count %><span class="small_font">/<%= past_schedule.recruitment_numbers %>名</span>
                      <% else %>
                        <i class="fa fa-users "></i> 参加人数：<%= past_schedule.name_schedules.where(answer: 1).count %>名
                      <% end %>
                    <% elsif past_schedule.name_schedules.where(answer: 1).count == 0 %>

                    <% else %>
                      <i class="fa fa-users "></i> 参加人数：<%= past_schedule.name_schedules.where(answer: 1).count %>名
                    <% end %>
                  </div>
                  <% if past_schedule.title.present? %>
                    <div class="schedule_title_list">
                      <%= past_schedule.title %>
                    </div>
                  <% end %>

                </div>

              <% end %>

          <% end %>
      <% end %>

  </div>


	<%= render "/layouts/ad_square" %>
	<div class="ad_space"></div>


  <%= paginate @past_schedules %>


<% end %>