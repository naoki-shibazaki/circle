<% @wdays =  ["日", "月", "火", "水", "木", "金", "土" ] %>
<div class="date_list_wrap">

  <% if @path.is('schedules#day') %>

    <ul>
      <% 14.times do |i| %>
        <% if i == 0 %>
          <%= link_to "/dates/#{Time.parse(@date).since(i.days).strftime("%Y/%m/%d")}" do %><li class="c_selected"><%= Time.parse(@date).since(i.days).strftime("#{@wdays[Time.parse(@date).since(i.days).wday]}") %><br><%= Time.parse(@date).since(i.days).strftime("%-d") %></li><% end %>
        <% elsif Time.parse(@date).since(i.days).strftime("#{@wdays[Time.parse(@date).since(i.days).wday]}") == "土" %>
          <%= link_to "/dates/#{Time.parse(@date).since(i.days).strftime("%Y/%m/%d")}" do %><li class="c_sat"><%= Time.parse(@date).since(i.days).strftime("#{@wdays[Time.parse(@date).since(i.days).wday]}") %><br><%= Time.parse(@date).since(i.days).strftime("%-d") %></li><% end %>
        <% elsif Time.parse(@date).since(i.days).strftime("#{@wdays[Time.parse(@date).since(i.days).wday]}") == "日" %>
          <%= link_to "/dates/#{Time.parse(@date).since(i.days).strftime("%Y/%m/%d")}" do %><li class="c_sun"><%= Time.parse(@date).since(i.days).strftime("#{@wdays[Time.parse(@date).since(i.days).wday]}") %><br><%= Time.parse(@date).since(i.days).strftime("%-d") %></li><% end %>
        <% else %>
          <%= link_to "/dates/#{Time.parse(@date).since(i.days).strftime("%Y/%m/%d")}" do %><li><%= Time.parse(@date).since(i.days).strftime("#{@wdays[Time.parse(@date).since(i.days).wday]}") %><br><%= Time.parse(@date).since(i.days).strftime("%-d") %></li><% end %>
        <% end %>
      <% end %>
    </ul>

    <div class="search_select">
        <select name="event_select" onChange="location.href=value;">
          <% if params[:event].present? %>
            <option value="#"><%= @event.name %></option>
          <% else %>
            <option value="#">サークル・チーム</option>
          <% end %>
          <% @categories.each do |category| %>
            <optgroup label="<%= category.name %>">
              <% category.events.each do |event| %>
                <% if params[:event] != event.ruby %>
                  <% if params[:pref].present? %>
                    <option value="/dates/<%= params[:year] %>/<%= params[:month] %>/<%= params[:day] %>?pref=<%= params[:pref] %>&event=<%= event.ruby %>"><%= event.name %></option>
                  <% else %>
                    <option value="/dates/<%= params[:year] %>/<%= params[:month] %>/<%= params[:day] %>?event=<%= event.ruby %>"><%= event.name %></option>
                  <% end %>
                <% end %>
              <% end %>
            </optgroup>
          <% end %>
        </select>

        <select name="prefecture_select" onChange="location.href=value;">
          <% if params[:pref].present? %>
            <option value="#"><%= @prefecture.name %></option>
          <% else %>
            <option value="#">都道府県</option>
          <% end %>
          <% @prefectures.each do |prefecture| %>
            <% if params[:pref] != prefecture.kana %>
              <% if params[:event].present? %>
                <option value="/dates/<%= params[:year] %>/<%= params[:month] %>/<%= params[:day] %>?event=<%= params[:event] %>&pref=<%= prefecture.kana %>"><%= prefecture.name %></option>
              <% else %>
                <option value="/dates/<%= params[:year] %>/<%= params[:month] %>/<%= params[:day] %>?pref=<%= prefecture.kana %>"><%= prefecture.name %></option>
              <% end %>
            <% end %>
          <% end %>
        </select>

        <div class="search_icon"><i class="fa fa-search "></i></div>
    </div>





  <% else %>
    <ul>
      <% 14.times do |i| %>
        <% if Time.zone.now.since(i.days).strftime("#{@wdays[Time.zone.now.since(i.days).wday]}") == "土" %>
          <%= link_to "/dates/#{Time.zone.now.since(i.days).strftime("%Y/%m/%d")}" do %><li class="c_sat"><%= Time.zone.now.since(i.days).strftime("#{@wdays[Time.zone.now.since(i.days).wday]}") %><br><%= Time.zone.now.since(i.days).strftime("%-d") %></li><% end %>
        <% elsif Time.zone.now.since(i.days).strftime("#{@wdays[Time.zone.now.since(i.days).wday]}") == "日" %>
          <%= link_to "/dates/#{Time.zone.now.since(i.days).strftime("%Y/%m/%d")}" do %><li class="c_sun"><%= Time.zone.now.since(i.days).strftime("#{@wdays[Time.zone.now.since(i.days).wday]}") %><br><%= Time.zone.now.since(i.days).strftime("%-d") %></li><% end %>
        <% else %>
          <%= link_to "/dates/#{Time.zone.now.since(i.days).strftime("%Y/%m/%d")}" do %><li><%= Time.zone.now.since(i.days).strftime("#{@wdays[Time.zone.now.since(i.days).wday]}") %><br><%= Time.zone.now.since(i.days).strftime("%-d") %></li><% end %>
        <% end %>
      <% end %>
    </ul>
  <% end %>

</div>