      <div class="attendance_url_copy">
        <div class="copyTarget">https://www.circle-book.com/u/<%= @user.link.unique_id %></div>
      </div>
      <button class="copyBtn mypage_url_copy"><div class="requirement_copy"><i class="fa fa-copy "></i> URLをコピーする！</div></button>




  <% if @schedules.present? %>

      <div class="schedule_list_copy">
        <div class="copyTarget">
          <% @schedules.each do |schedule| %>
              <% if schedule.present? %>

                    <% if @schedule_m_c != Time.parse(schedule.day).strftime("%-m") %>

                      【<%= Time.parse(schedule.day).strftime("%-m") %>月のスケジュール】<br>

                      <% @schedule_m_c = Time.parse(schedule.day).strftime("%-m") %>
                    <% end %>

                    ・<%= Time.parse(schedule.day).strftime("%-d日(#{%w(日 月 火 水 木 金 土)[Time.parse(schedule.day).wday]})") %>

                    <% if schedule.time_s.present? %>
                      <%= schedule.time_s.strftime('%H:%M') %>-<%= schedule.time_e.strftime('%H:%M') if schedule.time_e.present? %>
                    <% end %>
                    <% if schedule.member_venue.present? %>
                      <br>　<%= schedule.member_venue %><br>
                    <% else %>
                      <br>　<%= schedule.venue %><br>
                    <% end %>
                      <br>

              <% end %>
          <% end %>

          ▼スケジュール詳細
          <br>
          <%= request.url %>

        </div>
      </div>

    <button class="copyBtn"><div class="requirement_copy"><i class="fa fa-copy "></i> 全てのスケジュールをコピーする</div></button>

  <% end %>