<% set_meta_tags title: "サークルリンク"%>

<div class="main user-show">
  <div class="container bg_white link_index">

	<h1 class="p_t">サークルリンク</h1>

	<div class="swiper-container">

	    <div class="swiper-wrapper">
		    <img data-src="/images/circle_link01.jpg" class="lazyload swiper-slide" >
		 	<img data-src="/images/circle_link02.jpg" class="lazyload swiper-slide" >	
	    </div>

	    <div class="pagination-wrap">
	      <div class="swiper-pagination"></div>
	    </div>

	</div>


	<h2 class="links_sub_title">他の人のサークルリンク</h2>

    <ul class="sample_link_slide">
	    <% @links.each do |link| %>
			<li class="sample_link_child">

				<%= link_to "/link/#{link.unique_id}" do %>

					<div class="link_profile">

					      <% if link.user.pic_header.present? %>
					        <div class="link_img_header">
					          <%= lazysizes_image_tag link.user.pic_header.url, class:'header_link_imege', alt: "ヘッダー画像｜#{link.user.name}" %>
					        </div>
					      <% else %>
					        <div class="link_img_header">      
					          <%= lazysizes_image_tag link.user.pic_header.url , class:'header_link_imege' %>
					        </div>
					      <% end %>




					      <% if link.user.pic_profile.present? %>
					          <div class="link_img_profile">
					              <%= lazysizes_image_tag link.user.pic_profile.url, class:'profile_link_imege', alt: "プロフィール画像｜#{link.user.name}" %>
					          </div>
					      <% else %>
					          <div class="link_img_profile">
					              <%= lazysizes_image_tag link.user.pic_profile.url , class:'profile_link_imege' %>
					          </div>
					      <% end %>


					      <div class="link_name_wrap">
				                <div class="link_name"><%= link.user.name.truncate(10) %></div>
				                <div class="link_unique_id">@<%= link.unique_id %>
					      </div>

					</div>

					<div class="reset"></div>

					<div class="sample_link_title_wrap">

						<% if link.link01_title.present? %>
							<div class="sample_link_title">
								<%= link.link01_title.truncate(14) %>
							</div>
						<% end %>

						<% if link.link02_title.present? %>
							<div class="sample_link_title">
								<%= link.link02_title.truncate(14) %>
							</div>
						<% end %>

						<% if link.link03_title.present? %>
							<div class="sample_link_title">
								<%= link.link03_title.truncate(14) %>
							</div>
						<% end %>

					</div>


				<% end %>


			</li>
	    <% end %>
    </ul>



	<div class="contact_link circle_link_btm">
        <%= link_to(new_admin_user_registration_path) do %>
			<div class="btn btn_c btn_green btn_cubic">
				無料登録をして<br>
				サークルリンクを利用する！
			</div>
		<% end %>
	</div>

  </div>
</div>