<% set_meta_tags title: "#{@tag.text}！#{@prefecture.name}#{@city.name}の#{@event.txt}｜メンバー募集サイト",
                   keywords: "#{@event.name},#{@prefecture.name},#{@city.name},#{@tag.name},サークル,チーム",
              og: { 
              	image:image_url("/images/events/e_ogp_#{@event.ruby}.png")
              }
%>

<div class="main users-index">
  <div class="container">
 	<%= render "/layouts/breadcrumb" %>

		<div class="e_header_wrap">
			<img src="/images/events/e_icon_<%= @event.ruby %>.jpg" alt="<%= @event.name %>" >
			<div class="link_txt">
				<h1 class="e_header_title">
					<%= @tag.text %>の<br>
					<%= @prefecture.name %><%= @city.name %>で活動している<br>
					<%= @event.txt %>一覧
				</h1>
			</div>
		</div>


	<% if @users.count != 0 %>

		<%= render "/users/users_list.html.erb" %>
		    
	<% else @users.count == 0 %>

		<%= render "/tags/no_hit.html.erb" %>		
	
	<% end %>


  </div>
</div>