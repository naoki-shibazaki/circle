- set_meta_tags noindex: true,title: "集金管理ページ"
.main.users-index
  .container
    = render "/layouts/breadcrumb"
    .users-index-item
      .p_t 集金管理ページ
      - if admin_user_signed_in?
        - if @user.admin_user_id == current_admin_user.id
          - if @admin_user.users.count > 1
            .user_select_wrap
              現在のアカウント：
              %select{:name => "user_select", :onchange => "location.href=value;"}
                %option{:value => "#"}
                  = @user.name
                  （#{@user.event.name}）
                - @admin_user.users.each do |user|
                  - if @user.id != user.id
                    %option{:value => "/users/#{user.id}/collections"}
                      = user.name
                      （#{user.event.name}）
      .collection_add_wrap
        = form_for ([@user, @collection]) do |f|
          %p 日程を追加する
          .collection_add
            = f.text_field :day, id: 'datepicker', class: 'form-control form-day', readonly: "readonly", placeholder: "#{@time.strftime("%Y-%m-%d")}"
          .collection_add
            %input{"data-disable-with" => "追加", :name => "commit", :type => "submit", :value => "追加"}/
      = link_to "/users/#{@user.id}/collection-sample" do
        .collection_list
          %span.collection_day
            サンプルページ
            %br/
          人数：6人
          %br/
          金額：3500円
      - if @collections.present?
        .collection_list_wrap
          - @collections.each do |collection|
            - if collection.present?
              - if @collection_month != Time.parse(collection.day).strftime("%-m")
                .collection_m
                  【#{Time.parse(collection.day).strftime("%-m")}月】
                - @collection_month = Time.parse(collection.day).strftime("%-m")
              .collection_content_rwap
                = link_to(user_collection_path(@user.id, collection.id)) do
                  .collection_list
                    %span.collection_day
                      = Time.parse(collection.day).strftime("%-m月%-d日(#{%w(日 月 火 水 木 金 土)[Time.parse(collection.day).wday]})")
                      %br/
                    人数：#{collection.items.count}人
                    %br/
                    金額：#{collection.items.sum(:money)}円
                .collection_delete
                  = link_to("/users/#{@user.id}/collections/#{collection.id}", method: :delete, data: {confirm: "削除しますか？"}) do
                    %i.fa.fa-trash
      - if @collection_archives.present?
        .collection_list_wrap
          .collection_m 【アーカイブ】
          - @collection_archives.each do |collection_archive|
            - if collection_archive.present?
              .collection_content_rwap
                = link_to(user_collection_path(@user.id, collection_archive.id)) do
                  .collection_list
                    %span.collection_day
                      = Time.parse(collection_archive.day).strftime("%-m月%-d日(#{%w(日 月 火 水 木 金 土)[Time.parse(collection_archive.day).wday]})")
                      %br/
                    人数：#{collection_archive.items.count}人
                    %br/
                    金額：#{collection_archive.items.sum(:money)}円
                    .collection_delete
                      = link_to("/users/#{@user.id}/collections/#{collection_archive.id}", method: :delete, data: {confirm: "削除しますか？"}) do
                        %i.fa.fa-trash
