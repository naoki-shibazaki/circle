- set_meta_tags noindex: true,title: "集金管理ページ"
.main.users-index
  .container
    = render "/layouts/breadcrumb"
    .users-index-item
      %h1.collection_title= Time.parse(@collection.day).strftime("%-m月%-d日(#{%w(日 月 火 水 木 金 土)[Time.parse(@collection.day).wday]})")
      .collection_form
        = form_for ([@user, @collection]), url: "/users/#{@user.id}/collections/#{@collection.id}", method: :put do |f|
          %p 1人あたりの参加費
          .cp_iptxt
            .item_content
              = f.text_field :price, class: '',  placeholder: "500"
              %i.fa.fa-rmb.fa-lg.fa-fw{"aria-hidden" => "true"}
              %span.price 円
          %input{"data-disable-with" => "設定", :name => "commit", :type => "submit", :value => "設定"}/
      .collection_form
        = form_for ([@user, @collection, @item]), url: "/users/#{@user.id}/collections/#{@collection.id}/items" do |f|
          %p メンバーの追加
          .cp_iptxt
            .item_content.item_name
              = f.text_field :name, class: '', placeholder: "山田"
              %i.fa.fa-user.fa-lg.fa-fw{"aria-hidden" => "true"}
          .cp_iptxt
            .item_content
              = f.text_field :money, class: '', value: @collection.price, placeholder: "500"
              %i.fa.fa-rmb.fa-lg.fa-fw{"aria-hidden" => "true"}
              %span.price 円
          %input{"data-disable-with" => "追加", :name => "commit", :type => "submit", :value => "追加"}/
      .sum_people
        %span.sum_border
          人数　#{@sum_money.count}人／
          %span.sum_s
            = @collection.items.count
            人
      .sum_money
        %span.sum_border
          金額　#{@sum_money.sum(:money)}円／
          %span.sum_s
            = @collection.items.sum(:money)
            円
      - if @items.present?
        .collection_table
          %table
            - @items.each do |item|
              - if item.money.present?
                %tr
                  %td.text_c.w10
                    = link_to("/users/#{@user.id}/collections/#{@collection.id}/items/#{item.id}", method: :delete, data: {confirm: "削除しますか？"}) do
                      %i.fa.fa-trash
                  %td.text_c.w50= item.name
                  %td.text_r.w20
                    - if item.money.present?
                      = item.money
                      円
                  %td.text_c.w20
                    - if item.check == "check"
                      = link_to "/users/#{@user.id}/collections/#{@collection.id}/items/#{item.id}?check=", method: :put do
                        %span.checked
                          %i.fa.fa-check-square-o
                    - else item.check == ""
                      = link_to "/users/#{@user.id}/collections/#{@collection.id}/items/#{item.id}?check=check", method: :put do
                        %span.check
                          %i.fa.fa-square-o
